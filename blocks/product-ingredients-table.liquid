{%- liquid
  assign block_settings = block.settings
  assign product = closest.product
  assign rows = product.metafields.custom.ingredients_table.value
  assign rich_text_content = product.metafields.custom.ingredients

  if request.visual_preview_mode and rows == blank and rich_text_content == blank
    assign rows = null
    assign show_preview = true
  else
    assign show_preview = false
  endif

  assign has_table_rows = false
  if rows != blank and rows.size > 0
    assign has_table_rows = true
  endif

  assign has_rich_text = false
  if rich_text_content != blank
    assign has_rich_text = true
  endif
-%}

{%- if has_table_rows or has_rich_text or show_preview -%}
  <div
    class="product-ingredients-table spacing-style"
    style="{% render 'spacing-style', settings: block_settings %}"
    {{ block.shopify_attributes }}
  >
    {%- if block_settings.show_heading and block_settings.heading != blank -%}
      <h3 class="product-ingredients-table__heading">{{ block_settings.heading | escape }}</h3>
    {%- endif -%}

    {%- if has_table_rows -%}
      <div class="product-ingredients-table__wrapper">
        <table class="product-ingredients-table__table">
          <caption class="visually-hidden">{{ block_settings.heading | default: '成分表示' | escape }}</caption>
          <tbody>
            {%- for row in rows -%}
              {%- if row.label != blank or row.value != blank -%}
                <tr>
                  <th scope="row">{{ row.label | escape }}</th>
                  <td>{{ row.value | escape | newline_to_br }}</td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- elsif has_rich_text -%}
      <div class="product-ingredients-table__wrapper rte">
        {{ rich_text_content | metafield_tag }}
      </div>
    {%- elsif show_preview -%}
      <div class="product-ingredients-table__wrapper">
        <table class="product-ingredients-table__table">
          <caption class="visually-hidden">{{ block_settings.heading | default: '成分表示' | escape }}</caption>
          <tbody>
            <tr>
              <th scope="row">名称</th>
              <td>サンプル商品名</td>
            </tr>
            <tr>
              <th scope="row">原材料名</th>
              <td>茶葉（国内製造）</td>
            </tr>
            <tr>
              <th scope="row">内容量</th>
              <td>30g</td>
            </tr>
            <tr>
              <th scope="row">保存方法</th>
              <td>直射日光・高温多湿を避けて保存してください</td>
            </tr>
          </tbody>
        </table>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .product-ingredients-table {
    width: 100%;
  }

  .product-ingredients-table__heading {
    margin-block: 0 var(--padding-md);
    font-family: var(--font-heading--family);
    font-size: var(--font-h5--size);
    line-height: var(--font-h5--line-height);
    font-weight: var(--font-heading--weight);
  }

  .product-ingredients-table__wrapper {
    width: 100%;
    overflow-x: auto;
  }

  .product-ingredients-table__table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
  }

  .product-ingredients-table__table th,
  .product-ingredients-table__table td {
    padding: 12px 16px;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-10));
    text-align: start;
    vertical-align: top;
  }

  .product-ingredients-table__table th {
    width: 32%;
    max-width: 12rem;
    font-weight: 400;
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-5));
  }

  .product-ingredients-table__table tr:last-child th,
  .product-ingredients-table__table tr:last-child td {
    border-bottom: none;
  }

  .product-ingredients-table__wrapper.rte table {
    width: 100% !important;
  }

  @media screen and (max-width: 749px) {
    .product-ingredients-table__table th {
      width: 36%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_ingredients_table",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.product_ingredients_table"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "成分表示"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "t:settings.show_heading",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_ingredients_table",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
